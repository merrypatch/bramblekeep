# Copy to .env for local development (default values used if absent).
DATABASE_URL=sqlite://bramblekeep.db
BIND_ADDR=0.0.0.0:8080
FILES_DIR=files
RUST_LOG=info,sqlx=warn,tower_http=info

# Public URL for magic links (dev: Vite server).
PUBLIC_BASE_URL=http://localhost:5173
# Secure session cookie (set to true behind HTTPS in prod).
COOKIE_SECURE=false

# SMTP (optional). If SMTP_HOST is absent, login links are
# logged to the console instead of sent (dev mode, zero email config).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
# SMTP_FROM=Bramblekeep <no-reply@example.com>

# --- Updates ---
# URL of the release manifest. Default (if absent): latest.json from the latest
# GitHub release. In dev, point to a test manifest.
# UPDATE_MANIFEST_URL=https://github.com/merrypatch/bramblekeep/releases/latest/download/latest.json
# Interval for automatic update checking in seconds (default 86400 = 1x/day).
# UPDATE_CHECK_INTERVAL_SECS=86400
# Minisign public key (base64) to verify updates. EMPTY =
# apply disabled. Must correspond to the private signing key in the CI
# (secret MINISIGN_SECRET_KEY). Generate a pair: `minisign -G -W`.
# UPDATE_PUBLIC_KEY=

# --- Container updates (Docker only) ---
# In a container, bramblekeep cannot self-replace its binary. Point these at a
# Watchtower sidecar (see docker-compose.yml) and the in-app "Update" button
# will back up the DB and ask Watchtower to pull the new image + recreate the
# container. Leave empty on a bare-binary install (self-update is used instead).
# WATCHTOWER_URL=http://watchtower:8080/v1/update
# WATCHTOWER_TOKEN=change-me-update-token
